{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": {
        "npmInstallFlags": ["--legacy-peer-deps"]
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "node": {
        "npmInstallFlags": ["--legacy-peer-deps"]
      }
    },
    "production": {
      "autoIncrement": true,
      "node": {
        "npmInstallFlags": ["--legacy-peer-deps"]
      }
    }
  },
  "submit": {
    "production": {}
  }
}
